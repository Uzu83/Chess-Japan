# ===== フロントエンド(Vite) =====
# これらは VITE_ プレフィックス付き=ブラウザに露出する。秘密情報は絶対に置かない。
VITE_FEEDBACK_URL=
VITE_KOFI_URL=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ===== サーバー側(Supabase Edge Function)のみ =====
# 下記は Supabase の secrets に設定する。VITE_ プレフィックスを付けないこと(=ブラウザに出ない)。
#   supabase secrets set XAI_API_KEY=... など
XAI_API_KEY=
# 比較用(任意)
GEMINI_API_KEY=
# 既定プロバイダ: grok | gemini
LLM_PROVIDER=grok
