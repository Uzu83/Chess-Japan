# ===== フロントエンド(Vite) =====
# これらは VITE_ プレフィックス付き=ブラウザに露出する。秘密情報は絶対に置かない。
# フィードバック: Edge `feedback` が使えるときはアプリ内ダイアログ。未設定・障害時のフォールバック Form URL。
VITE_FEEDBACK_URL=
VITE_KOFI_URL=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Cloudflare Turnstile の "site key"（公開値・ブラウザ露出OK）。設定するとフロントが解説リクエスト毎に
# 新トークンを x-turnstile-token で送る。バックエンドの TURNSTILE_SECRET とペア（#2 の bot 防壁）。
# feedback Edge でも同じトークン経路を使う。
VITE_TURNSTILE_SITE_KEY=
# ログイン機能(Phase 2C)の有効化フラグ。'1' のときだけヘッダーにログイン UI が出る。
# 【重要・WHY このフラグが要るか】OAuth/Email はダッシュボード設定が済むまで動かない。
# 設定前に有効化すると「押すと壊れるログインボタン」が本番に出る。有効化の前提条件:
#   1. Google (+任意で Apple) OAuth クライアント作成
#      (Authorized redirect URI = https://<project-ref>.supabase.co/auth/v1/callback)
#   2. Supabase → Authentication → Providers: Google / Email を有効化
#   3. Supabase → Email の Confirm email = ON（必須。クラウド保存 RPC が確認済みを検査）
#   4. Supabase → URL Configuration: Site URL + Redirect URLs（本番/preview/localhost）
# 詳細手順: docs/operator/unblock-runbook.md タスク #25
# ビルド時焼き込み(設定変更後は再ビルド+再デプロイ)。
VITE_AUTH_ENABLED=
# OAuth ボタンの表示出し分け（'1' のときだけ各ボタン表示）。表示のみのフラグで、
# 実停止は Supabase Auth Provider 無効化で行う（キルスイッチではない）。
VITE_OAUTH_GOOGLE_ENABLED=
VITE_OAUTH_APPLE_ENABLED=
# 対人タブの表示出し分け（'1' + VITE_AUTH_ENABLED 有効時のみナビに出る）。表示のみ。
# 実停止は Edge Function disable / RPC REVOKE で行う。
VITE_PVP_ENABLED=
# パスキーは後続。独自ドメイン + 安定 RP ID が決まるまで立てない（誤有効化禁止）。
# VITE_PASSKEY_ENABLED=

# Sentry の DSN（公開値・ブラウザ露出OK）。未設定なら監視は完全オフ(ビルド時に SDK ごと除去される)。
# 【重要】ビルド時に焼き込まれる値 — 後から設定した場合は再ビルド + 再デプロイが必要。
# 【運用メモ・必須】DSN は公開されるため第三者が偽イベントを投げて quota を消費できる。
#   Sentry ダッシュボード → Settings → Security & Privacy → Allowed Domains に
#   chess-japan.pages.dev を設定して他ドメイン発のイベントを弾くこと(Codex ゲート①指摘)。
VITE_SENTRY_DSN=

# ===== サーバー側(Supabase Edge Function)のみ =====
# 下記は Supabase の secrets に設定する。VITE_ プレフィックスを付けないこと(=ブラウザに出ない)。
#   supabase secrets set ANTHROPIC_API_KEY=... など。ローカルにもgitにも置かない。
# コード上の既定は claude だが、本番は LLM_PROVIDER=gemini で運用中(2026-07 決定: 無料=Gemini Flash /
# 有料=Gemini Pro の Gemini 統一。WHY: Google AI Ultra の月次 GCP クレジット流用 — docs/PLAN.md 収益設計)。
# claude/grok は比較・フォールバック用に残す。
LLM_PROVIDER=claude
# 既定プロバイダ Claude のキー(LLM_PROVIDER=claude のとき必須)
ANTHROPIC_API_KEY=
# フォールバック/比較用(任意)
XAI_API_KEY=
GEMINI_API_KEY=
# モデル上書き(任意。未設定なら index.ts の既定 claude-sonnet-4-6 等)
CLAUDE_MODEL=
GROK_MODEL=
GEMINI_MODEL=
# bot 対策。課金キー(ANTHROPIC_API_KEY 等)がある環境では“必須”(未設定だと 503)。Turnstile の secret を入れる。
# キー無しの dev/preview では任意(未設定なら検証スキップ)。
TURNSTILE_SECRET=
# 本番では必須。許可するオリジンをカンマ区切りで(例 https://chess-japan.pages.dev)。
# 未設定だと本番(hosted)は安全側で全拒否、ローカルは許容。
ALLOWED_ORIGINS=
# レート制限/日次クォータの上書き(任意。未設定なら 15/分・200/日) — explain 用
RATE_PER_MIN=
RATE_PER_DAY=

# ===== フィードバック Edge Function（feedback）=====
# GitHub Issue 起票用。ブラウザに出さない。fine-grained PAT（1リポ・issues: write）推奨。
# 詳細: docs/operator/feedback-runbook.md / docs/feedback/ISSUE_CONTRACT.md
GITHUB_FEEDBACK_TOKEN=
GITHUB_FEEDBACK_REPO=
# 超過・障害時に UI へ返す Form URL（VITE_FEEDBACK_URL と同じでよい）
FEEDBACK_FALLBACK_URL=
# 上書き任意（既定 5/分・20/日 IP・50/日 global）
FEEDBACK_RATE_PER_MIN=
FEEDBACK_RATE_PER_DAY_IP=
FEEDBACK_RATE_GLOBAL_DAY=
