# dependencies
node_modules
.pnp
.pnp.js

# build
dist
dist-ssr
*.local
*.tsbuildinfo

# engine assets copied from node_modules at build time (large WASM, not committed)
public/engine
public/engine-shogi

# env / secrets — 絶対にコミットしない
.env
.env.*
!.env.example

# editor / os
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# test / coverage
coverage

# supabase
supabase/.temp
.supabase

# vite の依存事前バンドルキャッシュ(npm scripts 実行時に生成されることがある)
.vite

# --- /dev-secure が追記（DevSecOps 成果物） ---
# artifacts/ はスキャン結果・テスト結果・承認票の出力先。
# コミットしない理由: 成果物は「その commit 時点の証拠」であり、CI の
# Actions artifacts（retention 30〜90日）と Security タブが保存先。
# リポジトリに入れると diff ノイズ + 古い成果物を最新と誤読する事故のもと。
artifacts/
